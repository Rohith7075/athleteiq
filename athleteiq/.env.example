# ── AthleteIQ Environment Variables ────────────

# Google Gemini API key (optional for dev, users can also bring their own key via Settings)
# Get your key at: https://aistudio.google.com/apikey
# If not set, users must provide their own key in the Settings modal.
GEMINI_API_KEY=your_gemini_api_key_here

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=10

# ── AI Provider Options (set via Settings UI) ──
# Users can choose between:
#   1. Google Gemini (Cloud) — requires an API key (server default OR user's own key via Settings)
#   2. Ollama (Local) — free, runs on your machine at http://localhost:11434
# 
# These are configured through the Settings modal in the app
# and stored in the browser's localStorage under 'athleteiq_ai_config'.